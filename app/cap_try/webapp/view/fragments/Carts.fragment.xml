<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table">
    <Page showHeader="true" title="{i18n>carts_admin_report}">
    <Panel class="sapUiSmallMargin" expandable="true" expanded="true" expandAnimation="true" width="auto" headerText="{i18n>carts}">
        <table:Table id="cartsFragmentTable"
                     selectionMode="Single"
                     rowSelectionChange="onCartAdminTableSelection"
                     selectionBehavior="RowOnly"
                     alternateRowColors="true"
                     class="sapUiResponsiveMargin"
                     rows="{ path: '/Cart',
                             parameters: { expand: 'items,company' },
                             sorter: { path: 'createdAt', descending: false } }">
            <table:extension>
                <OverflowToolbar>
                    <ToolbarSpacer />
                    <Text text="{i18n>select_company_carts}" />
                    <Select width="auto" change="onCompanyChange" forceSelection="false" id="companyComboBox"
                            items="{ path: '/Company',
                                    sorter: { path: 'name' } }" >
                        <items>
                            <core:Item key="{ID}" text="{name}" />
                        </items>
                    </Select> 
                </OverflowToolbar>
            </table:extension>
            <table:columns>
                <table:Column width="20%">
                    <Label text="{i18n>id}" />
                    <table:template>
                        <Text text="{ID}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>created_by}" />
                    <table:template>
                        <Text text="{createdBy}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>name}" />
                    <table:template>
                        <Text text="{name}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>status}" />
                    <table:template>
                        <Text text="{status}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>total}" />
                    <table:template>
                        <ObjectNumber number="{cart_total}"
                                        unit="{currency/code}" />
                    </table:template>
                </table:Column>
            </table:columns>
            <table:footer>
            </table:footer>
        </table:Table>
    </Panel>
    <Panel expanded="false" class="sapUiSmallMargin" expandable="true" expandAnimation="true" headerText="{i18n>cart_items}">
        <table:Table id="cartItemsFragmentTable"
                     selectionMode="None"
                     alternateRowColors="true"
                     class="sapUiResponsiveMargin">
            <table:columns>
                <table:Column width="40%">
                    <Label text="{i18n>product}" />
                    <table:template>
                        <Text text="{product/name}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>price}" />
                    <table:template>
                        <ObjectNumber number="{product/price}"
                                      unit="{currency/code}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>quantity}" />
                    <table:template>
                        <Text text="{quantity}" />
                    </table:template>
                </table:Column>
                <table:Column width="20%">
                    <Label text="{i18n>total}" />
                    <table:template>
                        <ObjectNumber number="{total_price}"
                                      unit="{currency/code}" />
                    </table:template>
                </table:Column>
            </table:columns>
            <table:footer>
            </table:footer>
        </table:Table>
    </Panel>
</Page>
</core:FragmentDefinition> 