{
  "welcomeFile": "/cap_try/webapp/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/shop/(.*)$",
      "target": "/shop/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
